# Server
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# Database
DATABASE_URL=postgres://flowmesh:flowmesh@localhost:5432/flowmesh

# Redis / queue
REDIS_URL=redis://localhost:6379

# Workers
WORKER_CONCURRENCY=4

# Triggers
WEBHOOK_BASE_URL=http://localhost:4000

# Auth (for webhook signing)
WEBHOOK_SIGNING_SECRET=change-me-in-production
